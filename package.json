{
  "name": "frame-portal",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "test:coverage": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "coverage:check": "node tools/check-coverage.mjs",
    "new:feature": "node tools/new-feature.mjs",
    "e2e": "playwright test",
    "lint": "ng lint",
    "format": "prettier --write \"{src,e2e}/**/*.{ts,html,css}\" \"tools/**/*.mjs\"",
    "format:check": "prettier --check \"{src,e2e}/**/*.{ts,html,css}\" \"tools/**/*.mjs\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "{src,e2e}/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{html,css}": [
      "prettier --write"
    ],
    "tools/**/*.mjs": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@fontsource/outfit": "^5.2.8",
    "@jsverse/transloco": "^8.4.0",
    "@tanstack/angular-table": "^8.21.4",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.17",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "~5.1.0",
    "@types/qrcode": "^1.5.6",
    "angular-eslint": "21.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.46.4"
  }
}
